# =============================================================================
# Server Addresses
# =============================================================================
K8S_NODE_IP=<PRIMARY_K8S_NODE_IP>
STORAGE_HOST=<STORAGE_NODE_HOSTNAME>

# =============================================================================
# MinIO / S3 (on storage-head - HTTPS port 4000)
# =============================================================================
AWS_ACCESS_KEY_ID=<MINIO_ACCESS_KEY>
AWS_SECRET_ACCESS_KEY=<MINIO_SECRET_KEY>
AWS_ENDPOINT_URL=https://<STORAGE_NODE_IP>:4000
AWS_REGION=us-east-1

# =============================================================================
# Delta Lake
# =============================================================================
DELTA_ROOT=s3://delta-lake/bronze

# =============================================================================
# Hive Metastore (K8s - hive namespace)
# =============================================================================
HIVE_HOST=hms-hive-metastore.hive.svc.cluster.local
HIVE_PORT=9083

# =============================================================================
# Prefect (K8s - prefect namespace)
# =============================================================================
PREFECT_API_URL=http://<PRIMARY_K8S_NODE_IP>:4200/api

# =============================================================================
# Ray (K8s - ray namespace)
# =============================================================================
RAY_ADDRESS=ray://raycluster-persistent-head-svc.ray.svc:10001
RAY_SERVE_ENDPOINT=http://<RAY_SERVE_HOST>:8000
RAY_DASHBOARD_URL=http://<PRIMARY_K8S_NODE_IP>:32382

# =============================================================================
# LLM Providers
# =============================================================================
OPENAI_API_KEY=<OPTIONAL_OPENAI_API_KEY>
GOOGLE_API_KEY=<OPTIONAL_GOOGLE_API_KEY>
GEMINI_MODEL=gemini-2.5-flash
LLM_PROVIDER=gemini

# =============================================================================
# RisingWave (K8s - risingwave namespace)
# =============================================================================
RISINGWAVE_HOST=<PRIMARY_K8S_NODE_IP>
RISINGWAVE_PORT=31001

# =============================================================================
# TimescaleDB
# =============================================================================
TSDB_HOST=<PRIMARY_K8S_NODE_IP>
TSDB_PORT=5432
TSDB_USER=app
TSDB_PASSWORD=<TSDB_PASSWORD>
TSDB_DATABASE=app

# =============================================================================
# Redis (MetricsStore for Overseer/Gateway decoupling)
# =============================================================================
OVERSEER_REDIS_URL=redis://:<REDIS_PASSWORD>@redis-master.etl-storage.svc.cluster.local:6379/0

# =============================================================================
# Data Paths
# =============================================================================
INPUT_PATH=/mnt/data
