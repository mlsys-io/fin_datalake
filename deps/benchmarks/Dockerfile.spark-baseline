FROM etl-ray:latest-py312

USER root

RUN apt-get update \
    && apt-get install -y --no-install-recommends openjdk-17-jre-headless procps tini \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir "pyspark>=3.5,<4.0"

ENV JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
ENV SPARK_LOCAL_DIRS=/tmp/spark-local

RUN mkdir -p /tmp/spark-local /home/ray/.cache/pip \
    && chown -R ray:users /tmp/spark-local /home/ray/.cache

USER ray

WORKDIR /home/ray
