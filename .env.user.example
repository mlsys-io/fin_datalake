# =============================================================================
# User / Demo Overrides
# =============================================================================
# Copy to `.env.user` for local demo-specific settings that should not live in
# the core environment template.

# =============================================================================
# Demo Providers / Demo Runtime
# =============================================================================
FMP_API_KEY=<OPTIONAL_FMP_API_KEY>
DEMO_MARKET_DATA_PROVIDER=fmp
DEMO_SYMBOL=BTCUSD
DEMO_PRICE_WINDOW_SIZE=25
DEMO_PRICE_SERVICE_NAME=MarketPriceIngestService-BTCUSD
DEMO_PRICE_WEBSOCKET_URL=wss://stream.binance.com:9443/ws/btcusdt@trade
DEMO_PRICE_METRICS_CONTEXT_KEY=market_pulse:price_metrics:BTCUSD
DEMO_PRICE_SERVICE_READY_TIMEOUT_SECONDS=20
DEMO_MARKET_ANALYST_AGENT_NAME=MarketAnalyst-1
DEMO_GATEWAY_URL=http://localhost:8000
DEMO_GATEWAY_BEARER_TOKEN=<OPTIONAL_GATEWAY_BEARER_TOKEN>
DEMO_RISINGWAVE_PRICE_TABLE=market_pulse_prices
DEMO_RISINGWAVE_SIGNAL_TABLE=market_pulse_signals

# =============================================================================
# RisingWave Demo Query / Write Overrides
# =============================================================================
RISINGWAVE_USER=root
RISINGWAVE_PASSWORD=
RISINGWAVE_DATABASE=dev
RISINGWAVE_SCHEMA=public
